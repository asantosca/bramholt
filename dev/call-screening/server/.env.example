# Copy to .env and fill in. Never commit .env.

# Server
PORT=3000
# Your ngrok https URL (no trailing slash). Set after you start ngrok.
PUBLIC_URL=https://your-subdomain.ngrok-free.app

# Anthropic (Claude) — scam judgement
ANTHROPIC_API_KEY=sk-ant-...
# claude-sonnet-4-6 (fast, default) or claude-opus-4-8 (max quality)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_NUMBER=+1...
# Only needed for the Android Voice SDK token (app phase):
TWILIO_API_KEY_SID=SK...
TWILIO_API_KEY_SECRET=...
TWILIO_TWIML_APP_SID=AP...
TWILIO_PUSH_CREDENTIAL_SID=CR...

# Local Whisper. Default is the warm Python sidecar (faster-whisper) — see
# ../whisper-service. Start it, then leave these as-is.
WHISPER_MODE=http
WHISPER_SERVICE_URL=http://127.0.0.1:8000

# Alternative engine: whisper.cpp CLI. Set WHISPER_MODE=cli to use these instead.
# On Windows BIN might be C:/tools/whisper.cpp/build/bin/whisper-cli.exe
WHISPER_BIN=whisper-cli
WHISPER_MODEL=models/ggml-base.en.bin

# Tuning
JUDGE_INTERVAL_MS=4000
SCAM_THRESHOLD=0.7
